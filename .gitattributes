# 默认按文本处理，自动规范化为 LF 入库
* text=auto eol=lf

# 显式锁定文本类型为 LF
*.py    text eol=lf
*.md    text eol=lf
*.txt   text eol=lf
*.yml   text eol=lf
*.yaml  text eol=lf
*.json  text eol=lf
*.toml  text eol=lf
*.cfg   text eol=lf
*.sh    text eol=lf

# 二进制文件不做行尾转换
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.pdf   binary
*.ico   binary
*.ttf   binary
*.woff  binary
*.woff2 binary
